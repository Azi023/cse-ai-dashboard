# CSE Agent Configuration
# Copy to .env and fill with real values

# VPS API URL
VPS_URL=https://csedash.xyz

# Shared secret — must match AGENT_SECRET in the VPS .env
AGENT_SECRET=your-agent-secret-here

# ATrad broker credentials
ATRAD_USERNAME=your-atrad-username
ATRAD_PASSWORD=your-atrad-password
